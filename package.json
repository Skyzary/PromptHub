{
  "name": "prompthub-monorepo",
  "packageManager": "pnpm@10.33.2",
  "private": true,
  "workspaces": [
    "Apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "prettify": "turbo prettify -- --write '**/src/**/*.{ts,tsx,js,jsx,json,scss,css}'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "3.2.4",
    "turbo": "latest",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "vitest": "^4.1.5"
  }
}