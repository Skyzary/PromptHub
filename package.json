{
  "name": "prompthub",
  "displayName": "PromptHub",
  "version": "0.0.1",
  "description": "an extension to manage gemini prompts templates",
  "author": "skyzary & iamredl",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "prettify": "prettier --write src/**/*.{ts,tsx,js,jsx,json,scss,css}"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "plasmo": "^0.90.5",
    "prettier": "3.2.4",
    "sass": "^1.70.0",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.5"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ]
  }
}
